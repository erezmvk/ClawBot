#!/command/with-contenv bash
# Permanently disabled on this deployment.
#
# Original purpose: restore dpkg-selections from a restic snapshot and run
# `apt dselect-upgrade` to reinstall packages a previous container had
# installed at runtime. That makes sense on a long-lived VM.
#
# On DigitalOcean App Platform every redeploy spawns a fresh container built
# from the Dockerfile, which already includes every apt package this image
# needs. The "restore" step adds no value and used to:
#   - hold a restic lock for the duration of the dpkg-selections restore;
#   - if killed by the 120s timeout, leave a stale lock behind that broke the
#     subsequent 10-restore-state's snapshot listing.
#
# We now skip unconditionally. The dpkg-selections file from /etc/openclaw
# is still in the image for anyone who wants to inspect it.
echo "[restore-packages] Permanently disabled on this deployment (App Platform always builds packages from Dockerfile)"
exit 0
