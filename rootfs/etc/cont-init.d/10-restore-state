#!/command/with-contenv bash
# Restore state paths from restic backup.
#
# All restic calls are timeboxed. Listing snapshots from Spaces on a fresh
# container has no local cache and can stall for many minutes on a busy
# repository (hundreds of snapshots from a 30s backup interval). Without
# timeouts the container can't boot at all if Spaces is slow.
#
# Set SKIP_STATE_RESTORE=true as an emergency bypass - container will start
# fresh without any backed-up state. Use only when you're prepared to lose
# bot memory and re-import any state manually.

source /etc/s6-overlay/lib/env-utils.sh

# Load RESTIC_ vars. source_env_prefix sets the variables in this shell but
# doesn't export them. The `timeout` wrapper used below spawns restic as a
# child process which inherits ONLY exported variables - so restic would fail
# with "Please specify repository location" because RESTIC_REPOSITORY and
# RESTIC_PASSWORD aren't visible. Export everything restic needs explicitly.
source_env_prefix RESTIC_
export RESTIC_REPOSITORY RESTIC_PASSWORD AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY

if [ "${SKIP_STATE_RESTORE:-false}" = "true" ]; then
  echo "[restore-state] SKIP_STATE_RESTORE=true, skipping (container will start with no backed-up state)"
  exit 0
fi

# Check if persistence is configured
if [ -z "$RESTIC_REPOSITORY" ] || [ -z "$RESTIC_PASSWORD" ]; then
  echo "[restore-state] Persistence not configured, skipping"
  exit 0
fi

# Check if config exists
if [ ! -f "$RESTIC_BACKUP_CONFIG_FILE" ]; then
  echo "[restore-state] Config file not found: $RESTIC_BACKUP_CONFIG_FILE"
  exit 1
fi

# Clear stale locks from prior failed/killed restic operations. Without this,
# a single previous-container-crash leaves locks in the repo that block all
# subsequent read operations (including this script's snapshot listing).
echo "[restore-state] Clearing stale restic locks..."
timeout 30 restic unlock --remove-all 2>&1 || echo "[restore-state] (unlock warned/failed - continuing)"

# Check if repository has any snapshots (timeboxed). Use --no-lock to avoid
# acquiring a write lock on a read-only operation. Capture restic's exit code
# via PIPESTATUS[0] - NOT $? - because the pipe to grep would otherwise mask
# a timeout-124 as grep's "no-match-1". DO NOT redirect stderr to /dev/null
# here - we want restic errors visible so the boot log is debuggable.
echo "[restore-state] Listing snapshots from repository (120s timeout)..."
timeout 120 restic snapshots --no-lock --latest 1 2>&1 | tee /tmp/restic-snapshots.out | grep -q 'ID'
RESTIC_RC="${PIPESTATUS[0]}"
GREP_RC="${PIPESTATUS[2]}"

if [ "$RESTIC_RC" = "124" ]; then
  # Timed out. A repo with snapshots that we couldn't list is the most
  # dangerous case: booting fresh will let the backup loop snapshot the
  # empty /data/.openclaw on top of the user's real backups.
  echo "[restore-state] ERROR: Timed out listing snapshots from Spaces after 120s." >&2
  echo "[restore-state] Refusing to start openclaw to protect existing snapshots." >&2
  echo "[restore-state] Recovery: set ENABLE_SPACES=false, redeploy, then manually" >&2
  echo "[restore-state]           restic restore from a known-good snapshot." >&2
  echo "[restore-state] To bypass this guard (and start with empty state), set" >&2
  echo "[restore-state]           ALLOW_EMPTY_STATE_BOOT=true. This is dangerous - the" >&2
  echo "[restore-state]           backup loop will start snapshotting an empty state." >&2
  if [ "${ALLOW_EMPTY_STATE_BOOT:-false}" != "true" ]; then
    exit 1
  fi
  echo "[restore-state] ALLOW_EMPTY_STATE_BOOT=true - proceeding without restored state"
  exit 0
elif [ "$RESTIC_RC" != "0" ]; then
  echo "[restore-state] ERROR: restic snapshots exited with code $RESTIC_RC" >&2
  if [ "${ALLOW_EMPTY_STATE_BOOT:-false}" != "true" ]; then
    echo "[restore-state] Refusing to start openclaw. Set ALLOW_EMPTY_STATE_BOOT=true to bypass." >&2
    exit 1
  fi
  exit 0
elif [ "$GREP_RC" != "0" ]; then
  echo "[restore-state] No snapshots found in repository, skipping"
  exit 0
fi
echo "[restore-state] Snapshots present, proceeding with restore"

# Restore all paths in order (config has /etc first)
PATH_COUNT=$(yq -r '.paths | length' "$RESTIC_BACKUP_CONFIG_FILE")

if [ "$PATH_COUNT" -eq 0 ]; then
  echo "[restore-state] No paths configured for restore"
  exit 0
fi

echo "[restore-state] Restoring $PATH_COUNT paths..."

for i in $(seq 0 $((PATH_COUNT - 1))); do
  RESTORE_PATH=$(yq -r ".paths[$i].path" "$RESTIC_BACKUP_CONFIG_FILE")

  # Ensure parent directory exists
  mkdir -p "$(dirname "$RESTORE_PATH")"

  # Find latest snapshot for this specific path (timeboxed, no lock needed)
  echo "[restore-state] Looking up snapshot for $RESTORE_PATH..."
  SNAPSHOT_ID=$(timeout 90 restic snapshots --no-lock --path "$RESTORE_PATH" --latest 1 --json 2>/dev/null | jq -r '.[0].id // empty')

  if [ -z "$SNAPSHOT_ID" ]; then
    echo "[restore-state] No snapshot found for $RESTORE_PATH (or lookup timed out), skipping"
    continue
  fi

  echo "[restore-state] Restoring: $RESTORE_PATH (snapshot $SNAPSHOT_ID)"

  # Run restic restore from the snapshot that contains this path. Verbose so
  # we get periodic progress lines; timeboxed at 10 min per path so a single
  # huge path can't deadlock the whole boot.
  if timeout 600 restic restore "$SNAPSHOT_ID" --target / --include "$RESTORE_PATH" --verbose 2>&1; then
    echo "[restore-state] Completed: $RESTORE_PATH"
  else
    rc=$?
    if [ "$rc" = "124" ]; then
      echo "[restore-state] Timed out restoring $RESTORE_PATH after 10 min - continuing without it"
    else
      echo "[restore-state] Warning: Restore may have had issues for $RESTORE_PATH (continuing)"
    fi
  fi
done

# Permissions applied via /etc/digitalocean/permissions.yaml

echo "[restore-state] Restore complete"
