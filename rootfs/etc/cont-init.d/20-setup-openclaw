#!/command/with-contenv bash
# Generate openclaw gateway configuration
source /etc/s6-overlay/lib/env-utils.sh

set -e
source_env_prefix OPENCLAW_

# OpenClaw requires any env vars consumed in config to exist or else it fails to start.
persist_env_var OPENCLAW_ \
  GRADIENT_API_KEY=change-me \
  OPENAI_API_KEY="${OPENAI_API_KEY}" \
  MINIMAX_API_KEY="${MINIMAX_API_KEY}" \
  ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}" \
  AMADEUS_CLIENT_ID="${AMADEUS_CLIENT_ID}" \
  AMADEUS_CLIENT_SECRET="${AMADEUS_CLIENT_SECRET}" \
  AMADEUS_GUEST_OFFICE_ID="${AMADEUS_GUEST_OFFICE_ID}" \
  AMADEUS_ENV="${AMADEUS_ENV:-production}" \
  AMADEUS_RATE_CODES="${AMADEUS_RATE_CODES}" \
  MONDAY_API_TOKEN="${MONDAY_API_TOKEN}" \
  MONDAY_BOARD_IDS="${MONDAY_BOARD_IDS}" \
  TAILSCALE_ENABLE="${TAILSCALE_ENABLE:-false}" \
  TS_SOCKET="${TS_SOCKET}" \
  TS_EXTRA_ARGS="${TS_EXTRA_ARGS}" \
  TS_HOSTNAME="${TS_HOSTNAME}" \
  TS_STATE_DIR="${TS_STATE_DIR}" \
  TS_USERSPACE="${TS_USERSPACE}" \
  OPENCLAW_STATE_DIR=/data/.openclaw \
  OPENCLAW_WORKSPACE_DIR=/data/workspace \
  WHATSAPP_AGENT_GROUP_IDS="${WHATSAPP_AGENT_GROUP_IDS}" \
  WHATSAPP_WAKE_WORDS="${WHATSAPP_WAKE_WORDS}"

# Ensure directories exist (only if variables are set)
[ -n "$OPENCLAW_STATE_DIR" ] && mkdir -p "$OPENCLAW_STATE_DIR"
[ -n "$OPENCLAW_WORKSPACE_DIR" ] && mkdir -p "$OPENCLAW_WORKSPACE_DIR"

# Validate mutual exclusivity of ngrok and tailscale
if [ "${ENABLE_NGROK:-false}" = "true" ] && [ "${TAILSCALE_ENABLE:-false}" = "true" ]; then
  echo "[generate-config] WARNING: Both ENABLE_NGROK and TAILSCALE_ENABLE are true."
  echo "[generate-config] This doesn't make sense - ngrok is public, Tailscale is private."
  echo "[generate-config] Defaulting to Tailscale (disable ENABLE_NGROK to silence this)."
fi

# Setup openclaw user's .profile (used by login shells, no interactive check)
SOURCE_LINE="source /etc/s6-overlay/lib/env-utils.sh"
PROFILE="/home/openclaw/.profile"
# Create .profile if it doesn't exist
touch "$PROFILE"
chown openclaw:openclaw "$PROFILE"
# Append environment setup if not already present
if ! grep -qF "$SOURCE_LINE" "$PROFILE"; then
    cat >> "$PROFILE" <<'EOF'
# OpenClaw environment setup
source /etc/s6-overlay/lib/env-utils.sh 2>/dev/null || true
source_env_prefix OPENCLAW_ 2>/dev/null || true

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
EOF
    echo "Appended environment setup to $PROFILE"
fi

DEFAULT_CONFIG="/etc/openclaw/openclaw.default.json"
CONFIG_FILE="$OPENCLAW_STATE_DIR/openclaw.json"

echo "[generate-config] Building config: $CONFIG_FILE"

# Show version
echo "[generate-config] Checking openclaw installation..."
if ! command -v openclaw >/dev/null 2>&1; then
  echo "[generate-config] ERROR: openclaw command not found in PATH" >&2
  echo "[generate-config] PATH: $PATH" >&2
  echo "[generate-config] Node version: $(node --version 2>&1 || echo 'not found')" >&2
  exit 1
fi

echo "[generate-config] OpenClaw version: $(openclaw --version 2>/dev/null || echo 'unknown')"

# Generate a gateway token if not provided
if [ -z "$OPENCLAW_GATEWAY_TOKEN" ]; then
  OPENCLAW_GATEWAY_TOKEN=$(head -c 32 /dev/urandom | base64 | tr -d '=/+' | head -c 32)
  echo "[generate-config] Generated gateway token (ephemeral): $OPENCLAW_GATEWAY_TOKEN"
  echo "[generate-config] Save this token - you'll need it to connect to the Control UI"
fi

# Write token to s6 environment
persist_env_var OPENCLAW_ OPENCLAW_GATEWAY_TOKEN="$OPENCLAW_GATEWAY_TOKEN"
echo "[generate-config] Gateway token configured (OPENCLAW_GATEWAY_TOKEN)"

# Start with default config as base, but preserve restored config from backup
if [ -f "$CONFIG_FILE" ]; then
  echo "[generate-config] Existing config found (restored from backup), preserving user settings"
  # mcpServers is NOT a valid key in openclaw.json - openclaw rejects it with a schema error.
  # MCP server registration is done via mcporter's own config file (mcporter.json).
  # Remove the key if it was written by an older version of these init scripts.
  if jq -e '.mcpServers' "$CONFIG_FILE" >/dev/null 2>&1; then
    echo "[generate-config] Removing invalid mcpServers key from openclaw.json (belongs in mcporter.json)"
    jq 'del(.mcpServers)' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
  fi
  # Clean up agents.defaults.groupChat - groupChat belongs on agents.list[] items, not defaults
  if jq -e '.agents.defaults.groupChat' "$CONFIG_FILE" >/dev/null 2>&1; then
    echo "[generate-config] Removing invalid agents.defaults.groupChat key from config"
    jq 'del(.agents.defaults.groupChat)' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
  fi
elif [ -f "$DEFAULT_CONFIG" ]; then
  cp "$DEFAULT_CONFIG" "$CONFIG_FILE"
  echo "[generate-config] Using default config from $DEFAULT_CONFIG"
else
  # Fallback minimal config if default doesn't exist
  echo '{"gateway": {"mode": "local"}}' > "$CONFIG_FILE"
  echo "[generate-config] Warning: Default config not found, using minimal config"
fi

# Handle ENABLE_UI flag - disable Control UI if set to false
if [ "${ENABLE_UI:-true}" = "false" ]; then
  echo "[generate-config] Disabling Control UI (ENABLE_UI=false)"
  jq '.gateway.controlUi.enabled = false' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
fi

# Add Tailscale config when enabled, or clean it up when disabled
if [ "${TAILSCALE_ENABLE:-false}" = "true" ]; then
  echo "[generate-config] Adding Tailscale serve config"
  jq '.gateway.tailscale.resetOnExit = true | .gateway.tailscale.mode = "serve" | .gateway.auth.allowTailscale = true' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
else
  echo "[generate-config] Tailscale disabled - removing stale tailscale serve config if present"
  jq 'del(.gateway.tailscale) | .gateway.auth.allowTailscale = false' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
fi

# Ensure MiniMax provider exists in config when MINIMAX_API_KEY is set
if [ -n "${MINIMAX_API_KEY:-}" ]; then
  HAS_MINIMAX=$(jq -r '.models.providers.minimax // empty' "$CONFIG_FILE")
  if [ -z "$HAS_MINIMAX" ]; then
    echo "[generate-config] Injecting MiniMax provider (MINIMAX_API_KEY is set but provider missing from config)"
    jq '.models.providers.minimax = {
      "baseUrl": "https://api.minimax.chat/v1",
      "apiKey": "${MINIMAX_API_KEY}",
      "api": "openai-completions",
      "models": [
        {"id":"MiniMax-M2.7","name":"MiniMax M2.7","reasoning":true,"input":["text"],"contextWindow":1000000,"maxTokens":32768},
        {"id":"MiniMax-M2.7-highspeed","name":"MiniMax M2.7 Highspeed","reasoning":false,"input":["text"],"contextWindow":1000000,"maxTokens":32768},
        {"id":"MiniMax-M2.5","name":"MiniMax M2.5","reasoning":true,"input":["text"],"contextWindow":1000000,"maxTokens":32768},
        {"id":"MiniMax-M2.5-highspeed","name":"MiniMax M2.5 Highspeed","reasoning":false,"input":["text"],"contextWindow":1000000,"maxTokens":32768},
        {"id":"MiniMax-M2.1","name":"MiniMax M2.1","reasoning":true,"input":["text"],"contextWindow":1000000,"maxTokens":32768},
        {"id":"MiniMax-M2.1-highspeed","name":"MiniMax M2.1 Highspeed","reasoning":false,"input":["text"],"contextWindow":1000000,"maxTokens":32768},
        {"id":"MiniMax-M2","name":"MiniMax M2","reasoning":true,"input":["text"],"contextWindow":1000000,"maxTokens":32768}
      ]
    }' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
  fi
fi

# Ensure OpenAI provider exists in config when OPENAI_API_KEY is set
if [ -n "${OPENAI_API_KEY:-}" ]; then
  HAS_OPENAI=$(jq -r '.models.providers.openai // empty' "$CONFIG_FILE")
  if [ -z "$HAS_OPENAI" ]; then
    echo "[generate-config] Injecting OpenAI provider (OPENAI_API_KEY is set but provider missing from config)"
    jq '.models.providers.openai = {
      "baseUrl": "https://api.openai.com/v1",
      "apiKey": "${OPENAI_API_KEY}",
      "api": "openai-completions",
      "models": [
        {"id":"gpt-5.3","name":"GPT-5.3","reasoning":true,"input":["text","image"],"contextWindow":1047576,"maxTokens":32768},
        {"id":"gpt-5.2","name":"GPT-5.2","reasoning":true,"input":["text","image"],"contextWindow":1047576,"maxTokens":32768},
        {"id":"gpt-5-mini","name":"GPT-5 Mini","reasoning":false,"input":["text","image"],"contextWindow":1047576,"maxTokens":16384},
        {"id":"o3","name":"o3","reasoning":true,"input":["text","image"],"contextWindow":200000,"maxTokens":100000},
        {"id":"o4-mini","name":"o4-mini","reasoning":true,"input":["text","image"],"contextWindow":200000,"maxTokens":100000}
      ]
    }' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
  fi
fi

# Add gateway auth token to config
echo "[generate-config] Adding gateway.auth.token to config"
jq --arg token "$OPENCLAW_GATEWAY_TOKEN" '.gateway.auth.token = $token | .gateway.auth.mode = "token"' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"

# ---------------------------------------------------------------------------
# WhatsApp group agent routing
#
# WHATSAPP_AGENT_GROUP_IDS  - comma-separated WhatsApp group JIDs that should
#   be handled by the full agent (instead of the auto-reply path).
#   Defaults to the known Product Dev group if not set.
#
# WHATSAPP_WAKE_WORDS - comma-separated text patterns that count as a mention
#   inside those groups.  Defaults to "flashy,פלאשי".
#
# Both settings are injected on every container start so they survive config
# restores from backup that predate this feature.
# ---------------------------------------------------------------------------
WHATSAPP_AGENT_GROUP_IDS="${WHATSAPP_AGENT_GROUP_IDS:-120363407667070186@g.us}"
WHATSAPP_WAKE_WORDS="${WHATSAPP_WAKE_WORDS:-flashy,פלאשי}"

echo "[generate-config] Configuring WhatsApp agent groups: $WHATSAPP_AGENT_GROUP_IDS"
echo "[generate-config] Wake words: $WHATSAPP_WAKE_WORDS"

# Build the groups JSON object: {"<id>": {"requireMention": true}, ...}
GROUPS_JSON="{}"
IFS=',' read -ra _GROUP_IDS <<< "$WHATSAPP_AGENT_GROUP_IDS"
for _GID in "${_GROUP_IDS[@]}"; do
  _GID="${_GID// /}"   # strip spaces
  [ -z "$_GID" ] && continue
  GROUPS_JSON=$(printf '%s' "$GROUPS_JSON" | jq --arg id "$_GID" '. + {($id): {"requireMention": true}}')
done

# Build the wake-words JSON array: ["flashy", "פלאשי", ...]
WAKE_WORDS_JSON="[]"
IFS=',' read -ra _WAKE_WORDS <<< "$WHATSAPP_WAKE_WORDS"
for _WW in "${_WAKE_WORDS[@]}"; do
  _WW="${_WW// /}"
  [ -z "$_WW" ] && continue
  WAKE_WORDS_JSON=$(printf '%s' "$WAKE_WORDS_JSON" | jq --arg w "$_WW" '. + [$w]')
done

# Build per-group tool allow JSON: {"<id>": {"requireMention": true, "tools": {"alsoAllow": ["monday-boards.*"]}}}
GROUPS_WITH_TOOLS_JSON="{}"
for _GID in "${_GROUP_IDS[@]}"; do
  _GID="${_GID// /}"
  [ -z "$_GID" ] && continue
  GROUPS_WITH_TOOLS_JSON=$(printf '%s' "$GROUPS_WITH_TOOLS_JSON" | jq --arg id "$_GID" \
    '. + {($id): {"requireMention": true, "tools": {"alsoAllow": ["monday-boards.*"]}}}')
done

# Build bindings array: one entry per group routing to "main" agent
BINDINGS_JSON="[]"
for _GID in "${_GROUP_IDS[@]}"; do
  _GID="${_GID// /}"
  [ -z "$_GID" ] && continue
  BINDINGS_JSON=$(printf '%s' "$BINDINGS_JSON" | jq --arg id "$_GID" \
    '. + [{"agentId": "main", "match": {"channel": "whatsapp", "peer": {"kind": "group", "id": $id}}}]')
done

# Merge into config:
#  - channels.whatsapp.groups         <- requireMention + tools.alsoAllow (merged with pre-existing)
#  - agents.list[0].groupChat.mentionPatterns <- wake words (on list items, NOT agents.defaults)
#  - bindings                         <- routes each group to the main agent (not auto-reply)
#    Without a binding, openclaw falls through to the auto-reply handler even when a wake word fires.
#
# IMPORTANT: in jq, (A + B) means B wins for duplicate keys.
# We put $groups LAST so our injected values (requireMention + tools.alsoAllow) always
# win over whatever the restored config had for those group IDs.
jq --argjson groups "$GROUPS_WITH_TOOLS_JSON" \
   --argjson wakeWords "$WAKE_WORDS_JSON" \
   --argjson bindings "$BINDINGS_JSON" \
   '
   .channels.whatsapp.groups = ((.channels.whatsapp.groups // {}) + $groups) |
   if ((.agents.list // []) | length) > 0 then
     .agents.list[0].groupChat.mentionPatterns = $wakeWords
   else
     .agents.list = [{"id": "main", "default": true, "groupChat": {"mentionPatterns": $wakeWords}}]
   end |
   .bindings = ($bindings + [(.bindings // [])[] | select(.match.channel != "whatsapp" or .match.peer.kind != "group" or ((.match.peer.id) as $id | $bindings | map(.match.peer.id) | index($id) | not))])
   ' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"

echo "[generate-config] WhatsApp group routing configured."

# Permissions applied via /etc/digitalocean/permissions.yaml

echo "[generate-config] Final config:"
jq '.' "$CONFIG_FILE"

persist_env_var OPENCLAW_

echo "[generate-config] Done generating config"
