#!/command/with-contenv bash
# ---------------------------------------------------------------------------
# Register Amadeus Hotels MCP server with OpenClaw via mcporter.
#
# MCP server registration is stored in mcporter.json (NOT in openclaw.json -
# openclaw rejects mcpServers as an unrecognized key).
#
# mcporter.json location: ~/.openclaw/workspace/config/mcporter.json
# (which maps to /data/.openclaw/workspace/config/mcporter.json since
#  ~/.openclaw is symlinked to /data/.openclaw)
#
# This script writes directly to mcporter.json using jq, which is reliable
# and doesn't require the mcporter binary to be installed. If the binary IS
# present it also runs `mcporter config add` for forward-compatibility.
#
# Skipped silently if Amadeus credentials are not configured.
# ---------------------------------------------------------------------------

source /etc/s6-overlay/lib/env-utils.sh
source_env_prefix OPENCLAW_

MCP_SERVER_PATH="/home/openclaw/mcp-servers/amadeus-hotels/build/index.js"
MCPORTER_CONFIG_DIR="${OPENCLAW_STATE_DIR:-/data/.openclaw}/workspace/config"
MCPORTER_CONFIG="${MCPORTER_CONFIG_DIR}/mcporter.json"

# Skip if no Amadeus credentials are configured
if [ -z "${AMADEUS_CLIENT_ID:-}" ] || [ -z "${AMADEUS_CLIENT_SECRET:-}" ]; then
  echo "[amadeus-mcp] AMADEUS_CLIENT_ID or AMADEUS_CLIENT_SECRET not set - skipping MCP registration"
  exit 0
fi

# Skip if the server binary doesn't exist (build step may have failed)
if [ ! -f "$MCP_SERVER_PATH" ]; then
  echo "[amadeus-mcp] ERROR: MCP server not found at $MCP_SERVER_PATH" >&2
  echo "[amadeus-mcp] The image may need to be rebuilt." >&2
  exit 0
fi

# ---------------------------------------------------------------------------
# Path 1: Write directly to mcporter.json
# mcporter stores MCP server config at ~/.openclaw/workspace/config/mcporter.json
# in {"mcpServers": {"<name>": {"command": "...", "args": [...]}}} format.
# ---------------------------------------------------------------------------
mkdir -p "$MCPORTER_CONFIG_DIR"
chown -R openclaw:openclaw "$(dirname "$MCPORTER_CONFIG_DIR")" 2>/dev/null || true

echo "[amadeus-mcp] Registering Amadeus Hotels MCP server in $MCPORTER_CONFIG..."

# Read existing config or start with empty object, then merge our entry
if [ -f "$MCPORTER_CONFIG" ] && jq -e . "$MCPORTER_CONFIG" >/dev/null 2>&1; then
  # Merge: our entry wins (second operand wins in jq +)
  jq --arg path "$MCP_SERVER_PATH" \
     '.mcpServers["amadeus-hotels"] = {"command": "node", "args": [$path]}' \
     "$MCPORTER_CONFIG" > "${MCPORTER_CONFIG}.tmp" && mv "${MCPORTER_CONFIG}.tmp" "$MCPORTER_CONFIG"
else
  # Create fresh config
  jq -n --arg path "$MCP_SERVER_PATH" \
     '{"mcpServers": {"amadeus-hotels": {"command": "node", "args": [$path]}}}' \
     > "$MCPORTER_CONFIG"
fi

chown openclaw:openclaw "$MCPORTER_CONFIG"
echo "[amadeus-mcp] Amadeus Hotels MCP server registered in mcporter.json."

# ---------------------------------------------------------------------------
# Path 2: Also call mcporter CLI if binary is available (best-effort)
# ---------------------------------------------------------------------------
su - openclaw -c "
  export NVM_DIR=\"\$HOME/.nvm\"
  [ -s \"\$NVM_DIR/nvm.sh\" ] && . \"\$NVM_DIR/nvm.sh\"
  export PNPM_HOME=\"\$HOME/.local/share/pnpm\"
  export PATH=\"\$PNPM_HOME:\$PATH\"

  if command -v mcporter >/dev/null 2>&1; then
    mcporter config remove amadeus-hotels 2>/dev/null || true
    mcporter config add amadeus-hotels \\
      --command 'node $MCP_SERVER_PATH' 2>&1 \\
    && echo '[amadeus-mcp] Also confirmed via mcporter CLI.'
  fi
" 2>/dev/null || true
