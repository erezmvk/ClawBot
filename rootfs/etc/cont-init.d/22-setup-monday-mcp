#!/command/with-contenv bash
# ---------------------------------------------------------------------------
# Register Monday.com Boards MCP server with OpenClaw.
#
# Registration happens in TWO places:
#
# 1. openclaw.json under mcp.servers  (native openclaw key, written by
#    /mcp set).  This is the CRITICAL registration - without it openclaw does
#    not recognise "monday-boards" as a known provider and the group sandbox
#    allowlist fires:
#      "allowlist contains unknown entries (monday-boards.*)"
#
# 2. mcporter.json (mcporter skill's own config).  Kept for forward-compat
#    in case the mcporter binary is installed later.
#
# Note: mcpServers (root-level camelCase) is rejected by the openclaw schema
# validator.  Only the nested mcp.servers key is valid.
#
# Skipped silently if MONDAY_API_TOKEN is not configured.
# ---------------------------------------------------------------------------

source /etc/s6-overlay/lib/env-utils.sh
source_env_prefix OPENCLAW_

MCP_SERVER_PATH="/home/openclaw/mcp-servers/monday/build/index.js"
MCPORTER_CONFIG_DIR="${OPENCLAW_STATE_DIR:-/data/.openclaw}/workspace/config"
MCPORTER_CONFIG="${MCPORTER_CONFIG_DIR}/mcporter.json"

# Skip if no Monday API token is configured
if [ -z "${MONDAY_API_TOKEN:-}" ]; then
  echo "[monday-mcp] MONDAY_API_TOKEN not set - skipping MCP registration"
  exit 0
fi

# Skip if the server binary doesn't exist (build step may have failed)
if [ ! -f "$MCP_SERVER_PATH" ]; then
  echo "[monday-mcp] ERROR: MCP server not found at $MCP_SERVER_PATH" >&2
  echo "[monday-mcp] The image may need to be rebuilt." >&2
  exit 0
fi

# ---------------------------------------------------------------------------
# Path 1: Write directly to mcporter.json
# mcporter stores MCP server config at ~/.openclaw/workspace/config/mcporter.json
# in {"mcpServers": {"<name>": {"command": "...", "args": [...]}}} format.
# ---------------------------------------------------------------------------
mkdir -p "$MCPORTER_CONFIG_DIR"
chown -R openclaw:openclaw "$(dirname "$MCPORTER_CONFIG_DIR")" 2>/dev/null || true

echo "[monday-mcp] Registering Monday.com Boards MCP server in $MCPORTER_CONFIG..."

# Read existing config or start with empty object, then merge our entry
if [ -f "$MCPORTER_CONFIG" ] && jq -e . "$MCPORTER_CONFIG" >/dev/null 2>&1; then
  # Merge: our entry wins (second operand wins in jq +)
  jq --arg path "$MCP_SERVER_PATH" \
     '.mcpServers["monday-boards"] = {"command": "node", "args": [$path]}' \
     "$MCPORTER_CONFIG" > "${MCPORTER_CONFIG}.tmp" && mv "${MCPORTER_CONFIG}.tmp" "$MCPORTER_CONFIG"
else
  # Create fresh config
  jq -n --arg path "$MCP_SERVER_PATH" \
     '{"mcpServers": {"monday-boards": {"command": "node", "args": [$path]}}}' \
     > "$MCPORTER_CONFIG"
fi

chown openclaw:openclaw "$MCPORTER_CONFIG"
echo "[monday-mcp] Monday.com Boards MCP server registered in mcporter.json."

# ---------------------------------------------------------------------------
# Path 2: Register in openclaw.json under mcp.servers  (THE CRITICAL STEP)
#
# This is the native openclaw MCP server registry (read/written by /mcp set).
# Without this registration openclaw does not recognise "monday-boards" as a
# known provider at startup, so the per-group tools.alsoAllow check fires:
#   "allowlist contains unknown entries (monday-boards.*)"
# and the group agent cannot use any monday-boards.* tools.
#
# Script 20-setup-openclaw runs before this script and has already written
# openclaw.json, so we can safely patch it here.
# ---------------------------------------------------------------------------
CONFIG_FILE="${OPENCLAW_STATE_DIR:-/data/.openclaw}/openclaw.json"

if [ -f "$CONFIG_FILE" ] && jq -e . "$CONFIG_FILE" >/dev/null 2>&1; then
  echo "[monday-mcp] Registering monday-boards in openclaw.json mcp.servers..."
  jq --arg path "$MCP_SERVER_PATH" \
     '.mcp.servers["monday-boards"] = {"command": "node", "args": [$path]}' \
     "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
  chown openclaw:openclaw "$CONFIG_FILE" 2>/dev/null || true
  echo "[monday-mcp] monday-boards registered in openclaw.json mcp.servers."
else
  echo "[monday-mcp] WARNING: $CONFIG_FILE not found or invalid JSON - cannot register in mcp.servers" >&2
  echo "[monday-mcp] Group tool allowlist will not work for monday-boards tools" >&2
fi

# ---------------------------------------------------------------------------
# Path 3: Also call mcporter CLI if binary is available (best-effort)
# ---------------------------------------------------------------------------
su - openclaw -c "
  export NVM_DIR=\"\$HOME/.nvm\"
  [ -s \"\$NVM_DIR/nvm.sh\" ] && . \"\$NVM_DIR/nvm.sh\"
  export PNPM_HOME=\"\$HOME/.local/share/pnpm\"
  export PATH=\"\$PNPM_HOME:\$PATH\"

  if command -v mcporter >/dev/null 2>&1; then
    mcporter config remove monday-boards 2>/dev/null || true
    mcporter config add monday-boards \\
      --command 'node $MCP_SERVER_PATH' 2>&1 \\
    && echo '[monday-mcp] Also confirmed via mcporter CLI.'
  fi
" 2>/dev/null || true
